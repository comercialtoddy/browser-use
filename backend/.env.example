# Arquivo de exemplo para configuração das chaves de API
# Renomeie para .env e preencha com suas chaves

# OpenAI (GPT-4, GPT-3.5, GPT-4o, etc.)
OPENAI_API_KEY=

# Google (Gemini 1.5, 2.0, 2.5, etc.)
GEMINI_API_KEY=

# Anthropic (Claude 3.5, 3.6, 3.7, etc.)
ANTHROPIC_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# xAI (Grok)
GROK_API_KEY=

# Configurações do servidor
HOST=0.0.0.0
PORT=5000

# Configurações do navegador
# Para usar um Chrome existente, descomente e configure:
# CHROME_CDP=
# CHROME_PATH=
# CHROME_USER_DATA=

# Set to false to disable anonymized telemetry
ANONYMIZED_TELEMETRY=true

# LogLevel: Set to debug to enable verbose logging, set to result to get results only. Available: result | debug | info
BROWSER_USE_LOGGING_LEVEL=info

# set this to true to optimize browser-use's chrome for running inside docker
IN_DOCKER=false
